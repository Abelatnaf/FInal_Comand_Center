NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Assistant (/assistant). Both free, no credit card required. Gemini is
# tried first; if it's unset or fails, the app automatically falls back to
# Groq. Set either one (or both, for redundancy).
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional. Upgrades the secondary-currency conversion on Home from the
# free keyless open.er-api.com to exchangerate-api.com's keyed v6 API
# (more generous free tier: 1,500 requests/month). Get a key at
# https://www.exchangerate-api.com/ — the app works fine without this.
EXCHANGERATE_API_KEY=
