NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required only for the notification cron routes (app/api/cron/**).
# Service role key from Supabase dashboard → Settings → API. Never expose
# this to the browser — it bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
# API key from your email provider (resend.com by default — see
# lib/notifications/send-email.ts to swap providers).
RESEND_API_KEY=
# Optional override for the "from" address on notification emails.
NOTIFICATIONS_FROM_EMAIL=
# Optional but recommended: protects the cron routes from being triggered
# by anyone who finds the URL. Vercel automatically sends this as a Bearer
# token on cron-triggered requests once it's set as an env var.
CRON_SECRET=
